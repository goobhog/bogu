(defun help ()
  "Prints the Bogu command cheat sheet."
  (format t "~%===========================================================~%")
  (format t "                       BOGU HELP MENU                        ~%")
  (format t "===========================================================~%~%")
  
  (format t " [ NOTES & BASIC ENTRY ]~%")
  (format t "  <note> <rval> : Enter a note (e.g., c4 q, eb3 .5, f#5 qt)~%")
  (format t "  rst <rval>    : Advance the playhead by the specified rhythm.~%")
  (format t "  del <n>       : Delete the last <n> notes on the CURRENT track.~%")
  (format t "  rpt <n>       : Repeat the last <n> notes on the CURRENT track.~%~%")
  
  (format t " [ SEQUENCES & CHORDS ]~%")
  (format t "  seq <rval> <notes>  : Sequence of notes (e.g., seq q c4 e4 g4)~%")
  (format t "  poly <rval> <notes> : Enter a chord (preserves global time).~%")
  (format t "  sarp <rval> <sval> <notes> : Sustained arpeggio (rhythm & sustain length).~%")
  (format t "  fluid <rval> <notes>: Scatters notes randomly within a time boundary.~%~%")
  
  (format t " [ TIME, TRACKS, & ENVIRONMENT ]~%")
  (format t "  bpm <n>        : Set beats per minute (e.g., bpm 144).~%")
  (format t "  i <n>          : Change active instrument track (e.g., i 1, i 2).~%")
  (format t "  where          : Display the current timeline position of all tracks.~%")
  (format t "  cell <rval> [commands] : Creates a protected micro-timeline bucket.~%")
  (format t "  reset          : Wipe score and reset all global variables to 0.~%~%")

  (format t " [ THE STANDARD LIBRARY & VARIABLES ]~%")
  (format t "  def <name> <commands> : Bind notes/blocks to a variable (O(1) lookup).~%")
  (format t "  vars                  : View all saved variables in memory.~%")
  (format t "  *Built-in stdlib variables: maj, min, dim, aug, maj7, min7, dom7, dim7~%")
  (format t "                              arp-up, arp-down, arp-broken, rack-basic~%~%")

  (format t " [ HARDWARE & PLAYBACK ]~%")
  (format t "  play-live      : Stream the timeline to Csound in the background.~%")
  (format t "  stop           : Transport stop. Halts playback without wiping memory.~%")
  (format t "  synth <id> <name> : Load a synth cartridge (SINE, SAW, PLUCK).~%")
  (format t "  reboot         : Flash the hardware rack and reboot Csound.~%")
  (format t "  vol <0-100>    : Set the master velocity (Default: 80).~%")
  (format t "  transpose <n> [ <commands> ] : Shift the pitch of a block by n semitones.~%")
  (format t "  save \"name\"    : Save composition to a .bogu and .csd file.~%")
  (format t "  load \"name\"    : Load a saved .bogu file.~%")
  (format t "  play \"name\"    : Render and play the saved .csd file offline.~%")

  (format t "~%--- LOGIC & ITERATION -------------------------------------~%")
  (format t " loop <n> [ <commands> ]~%")
  (format t "   Repeats the commands inside the brackets N times.~%")
  (format t "   Ex: loop 4 [ sarp et h c4 ]~%~%")
  
  (format t " chance <%> [ <true-commands> ] [ <optional-false> ]~%")
  (format t "   Executes the first block with a % probability.~%")
  (format t "   Ex: chance 75 [ seq q c4 ] [ seq q g4 ]~%~%")
  
  (format t "===========================================================~%~%"))
